<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="accent_purple">#BB86FC</color>
    <color name="accent_purple_dark">#7C4DFF</color>
    <color name="background_dark">#121212</color>
    <color name="error_red">#CF6679</color>
    <color name="surface_dark">#1E1E1E</color>
    <color name="surface_light">#2D2D2D</color>
    <color name="text_hint">#808080</color>
    <color name="text_primary">#FFFFFF</color>
    <color name="text_secondary">#B0B0B0</color>
    <string name="app_name">MeowPlay</string>
    <style name="Theme.MeowPlay" parent="Theme.Leanback">
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorAccent">@color/accent_purple</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:windowBackground">@color/background_dark</item>
    </style>
    <style name="Theme.MeowPlay.Player" parent="Theme.Leanback">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>