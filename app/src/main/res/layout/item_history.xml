<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_history_item"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:descendantFocusability="afterDescendants">

    <!-- Copy button (LEFT side) -->
    <ImageView
        android:id="@+id/btn_copy"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_copy"
        android:padding="8dp"
        android:background="@drawable/bg_icon_button"
        android:contentDescription="Copy link"
        android:focusable="true"
        android:layout_marginEnd="12dp" />

    <!-- Content area -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:id="@+id/text_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- URL -->
        <TextView
            android:id="@+id/text_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="middle"
            android:layout_marginTop="2dp" />

        <!-- Timestamp and play count row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/text_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_hint"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/text_play_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/accent_purple_light"
                android:textSize="11sp"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- Resume indicator -->
        <TextView
            android:id="@+id/text_resume"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent_purple"
            android:textSize="12sp"
            android:visibility="gone"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Delete button -->
    <ImageView
        android:id="@+id/btn_delete"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_delete"
        android:padding="6dp"
        android:background="@drawable/bg_icon_button"
        android:contentDescription="Delete from history"
        android:focusable="true"
        android:layout_marginStart="8dp" />

</LinearLayout>
