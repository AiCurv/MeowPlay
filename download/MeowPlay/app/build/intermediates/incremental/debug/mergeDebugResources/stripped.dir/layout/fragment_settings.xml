<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Advanced Cache Settings"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configure how MeowPlay caches video data for optimal playback"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- ═══ Disk Cache Row ═══ -->
        <LinearLayout
            android:id="@+id/disk_cache_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_settings_row"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:focusable="true"
            android:layout_marginBottom="2dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/disk_cache_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Video Disk Cache"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saved video data on disk for faster replay"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/disk_cache_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto"
                android:textColor="@color/accent_purple"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- ═══ RAM Buffer Row ═══ -->
        <LinearLayout
            android:id="@+id/ram_buffer_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_settings_row"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:focusable="true"
            android:layout_marginBottom="2dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/ram_buffer_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Video Buffer Size (RAM)"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="In-memory buffer for smooth playback"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/ram_buffer_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto"
                android:textColor="@color/accent_purple"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- ═══ Buffer Length Row ═══ -->
        <LinearLayout
            android:id="@+id/buffer_length_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_settings_row"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:focusable="true"
            android:layout_marginBottom="2dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/buffer_length_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Video Buffer Length"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="How far ahead to buffer video data"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/buffer_length_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto"
                android:textColor="@color/accent_purple"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- ═══ Back Buffer Row ═══ -->
        <LinearLayout
            android:id="@+id/back_buffer_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_settings_row"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:focusable="true"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/back_buffer_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Back Buffer (Rewind Cache)"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Video data kept behind current position"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/back_buffer_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto"
                android:textColor="@color/accent_purple"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- ═══ Divider ═══ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/surface_light"
            android:layout_marginBottom="16dp" />

        <!-- ═══ Current Cache Size ═══ -->
        <TextView
            android:id="@+id/current_cache_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Current cache: calculating..."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <!-- ═══ Clear Cache Button ═══ -->
        <TextView
            android:id="@+id/clear_cache_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Clear Video &amp; Image Cache"
            android:textColor="@color/error_red"
            android:textSize="15sp"
            android:gravity="center"
            android:background="@drawable/bg_button_danger"
            android:focusable="true"
            android:layout_marginBottom="24dp" />

        <!-- ═══ Divider ═══ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/surface_light"
            android:layout_marginBottom="16dp" />

        <!-- ═══ Remote Toggle Row ═══ -->
        <LinearLayout
            android:id="@+id/remote_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_settings_row"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:focusable="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/remote_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mobile Remote Control"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enable remote API for MeowPlay mobile app"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/remote_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disabled"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
