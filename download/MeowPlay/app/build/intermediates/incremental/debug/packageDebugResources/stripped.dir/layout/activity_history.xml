<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/back_btn"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Back"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_btn_glass"
            android:focusable="true"
            android:layout_marginEnd="12dp" />

        <EditText
            android:id="@+id/search_input"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:hint="Search history..."
            android:textColorHint="#808080"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_input_focus"
            android:padding="10dp"
            android:singleLine="true"
            android:inputType="text"
            android:focusable="true"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/clear_all_btn"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Clear All"
            android:textColor="#CF6679"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_btn_glass"
            android:focusable="true" />
    </LinearLayout>

    <TextView
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="No history yet\n\nPlay a video or paste a link to get started!"
        android:textColor="#808080"
        android:textSize="16sp"
        android:gravity="center"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/history_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

</LinearLayout>
