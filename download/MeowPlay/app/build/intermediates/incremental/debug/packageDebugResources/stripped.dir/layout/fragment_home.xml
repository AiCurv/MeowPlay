<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <!-- Logo -->
        <ImageView
            android:id="@+id/logo_image"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@mipmap/ic_launcher"
            android:layout_marginBottom="16dp"
            android:contentDescription="MeowPlay Logo" />

        <!-- Welcome Text -->
        <TextView
            android:id="@+id/welcome_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MeowPlay"
            android:textColor="@color/text_primary"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Paste a video link to start watching"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:layout_marginBottom="32dp" />

        <!-- URL Input -->
        <EditText
            android:id="@+id/url_input"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Paste video URL here..."
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:singleLine="true"
            android:imeOptions="actionGo"
            android:inputType="textUri"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_marginBottom="16dp" />

        <!-- Play Button -->
        <Button
            android:id="@+id/play_button"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:text="Play"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_button_primary"
            android:drawableStart="@drawable/ic_play"
            android:drawablePadding="8dp"
            android:focusable="true"
            android:layout_marginBottom="32dp" />

        <!-- Supported Formats -->
        <TextView
            android:id="@+id/supported_formats_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Supported formats:\nMP4, MKV, AVI, WebM, M3U8/HLS, DASH, FLV, MOV\n\nWorks with: Stremio, CloudStream, Kodi, and any app that shares video links"
            android:textColor="@color/text_hint"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>
</ScrollView>
