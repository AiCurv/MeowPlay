<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark"
    android:padding="16dp">

    <!-- Header with search and clear all -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <!-- Search input -->
        <EditText
            android:id="@+id/search_input"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:hint="Search history..."
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_input"
            android:padding="10dp"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="8dp"
            android:layout_marginEnd="8dp" />

        <!-- Clear all button -->
        <ImageView
            android:id="@+id/clear_all_button"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_delete_all"
            android:padding="8dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="Clear all history"
            android:focusable="true" />

    </LinearLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="@color/accent_purple" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="No history yet\n\nPlay a video or paste a link to get started!"
        android:textColor="@color/text_hint"
        android:textSize="16sp"
        android:gravity="center"
        android:visibility="gone" />

    <!-- History list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/history_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

</LinearLayout>
